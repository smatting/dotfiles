#!/usr/bin/env python3

import argparse
import math
import os
import signal
import subprocess
import sys
import tempfile
from datetime import datetime, timezone

import requests

signal.signal(signal.SIGPIPE, signal.SIG_DFL)


def _auth():
    return (os.environ['JOT_API_USER'], os.environ['JOT_API_PASSWORD'])


def _url(path):
    return os.environ['JOT_API_URL'].rstrip('/') + path


def open_editor(initial=''):
    editor = os.environ.get('EDITOR', 'nano')
    with tempfile.NamedTemporaryFile(mode='w', suffix='.txt', delete=False) as f:
        f.write(initial)
        fname = f.name
    try:
        subprocess.call([editor, fname])
        with open(fname) as f:
            return f.read()
    finally:
        os.unlink(fname)


def cmd_add(args):
    if args.text:
        text = args.text
    elif not sys.stdin.isatty():
        text = sys.stdin.read()
    else:
        text = open_editor()
    text = text.strip()
    if not text:
        print('cancelled')
        return
    try:
        r = requests.post(_url('/api/jots'), json={'content': text}, auth=_auth())
        r.raise_for_status()
        print(f'Jot #{r.json()["id"]} created')
    except Exception as e:
        draft_path = os.path.expanduser('~/.jot_draft')
        with open(draft_path, 'w') as f:
            f.write(text)
        print(f'error: could not save jot ({e})', file=sys.stderr)
        print(f'draft saved to {draft_path}', file=sys.stderr)
        sys.exit(1)


def cmd_modify(args):
    r = requests.get(_url(f'/api/jots/{args.id}'), auth=_auth())
    if r.status_code == 404:
        print(f'error: jot #{args.id} not found', file=sys.stderr)
        sys.exit(1)
    r.raise_for_status()
    current = r.json()['content']
    text = open_editor(initial=current)
    text = text.strip()
    if not text:
        print('cancelled')
        return
    if text == current:
        print('no changes')
        return
    r = requests.put(_url(f'/api/jots/{args.id}'), json={'content': text}, auth=_auth())
    r.raise_for_status()
    print(f'Jot #{args.id} updated')


def cmd_delete(args):
    r = requests.delete(_url(f'/api/jots/{args.id}'), auth=_auth())
    if r.status_code == 404:
        print(f'error: jot #{args.id} not found', file=sys.stderr)
        sys.exit(1)
    r.raise_for_status()
    print(f'Jot #{args.id} deleted')


def relative_time(ts):
    diff = int(datetime.now(tz=timezone.utc).timestamp()) - ts
    if diff < 60:
        return f'{diff}s ago'
    elif diff < 3600:
        return f'{diff // 60}m ago'
    elif diff < 86400:
        return f'{diff // 3600}h ago'
    elif diff < 7 * 86400:
        return f'{diff // 86400}d ago'
    elif diff < 30 * 86400:
        return f'{diff // (7 * 86400)}w ago'
    elif diff < 365 * 86400:
        return f'{diff // (30 * 86400)}mo ago'
    else:
        return f'{diff // (365 * 86400)}y ago'


def cmd_list(args):
    r = requests.get(_url('/api/jots'), params={'page': args.page}, auth=_auth())
    r.raise_for_status()
    data = r.json()
    if args.plain:
        for jot in data['jots']:
            print(jot['content'])
            print('---')
    else:
        for jot in data['jots']:
            content = ' '.join(jot['content'].splitlines())
            id_str = f'#{jot["id"]}'
            ts = relative_time(jot['created_at'])
            footer = f'{id_str}  {ts}'
            text_w = max(len(content), len(footer))
            print(f'╭{"─" * (text_w + 2)}╮')
            print(f'│ {content:<{text_w}} │')
            print(f'│ {id_str}{ts:>{text_w - len(id_str)}} │')
            print(f'╰{"─" * (text_w + 2)}╯')
    total_pages = math.ceil(data['total'] / data['page_size']) if data['total'] else 1
    print(f'Page {data["page"]}/{total_pages} ({data["total"]} total)')


parser = argparse.ArgumentParser(prog='jot')
sub = parser.add_subparsers(dest='cmd', required=False)

p_add = sub.add_parser('add', help='Create a new jot (opens $EDITOR if no text given)')
p_add.add_argument('text', nargs='?', default=None)

p_list = sub.add_parser('list', help='List jots')
p_list.add_argument('--page', '-p', type=int, default=1)
p_list.add_argument('--plain', action='store_true')

p_modify = sub.add_parser('edit', help='Edit a jot in $EDITOR')
p_modify.add_argument('id', type=int)

p_delete = sub.add_parser('delete', help='Delete a jot')
p_delete.add_argument('id', type=int)

args = parser.parse_args()
if args.cmd is None:
    args.cmd = 'add'
    args.text = None

if args.cmd == 'add':
    cmd_add(args)
elif args.cmd == 'list':
    cmd_list(args)
elif args.cmd == 'edit':
    cmd_modify(args)
elif args.cmd == 'delete':
    cmd_delete(args)
